{
  "name": "AI-Powered Hospital Emergency Detection & Triage Chatbot",
  "nodes": [
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const rawInput = $json.chatInput || $json.body?.userInput || \"\";\n\nconst input = rawInput\n  .toLowerCase()\n  .replace(/[^a-z0-9\\s]/g, \"\")\n  .replace(/\\s+/g, \" \")\n  .trim();\n\n// Emergency categories\nconst emergencyCategories = {\n  \"Cardiac Emergency\": [\n    \"chest pain\",\n    \"heart pain\",\n    \"heart attack\",\n    \"chest pressure\"\n  ],\n\n  \"Respiratory Emergency\": [\n    \"cant breathe\",\n    \"can not breathe\",\n    \"difficulty breathing\",\n    \"shortness of breath\",\n    \"breathless\",\n    \"hard to breathe\",\n    \"trouble breathing\",\n    \"taking breath is difficult\"\n  ],\n\n  \"Stroke Emergency\": [\n    \"stroke\",\n    \"face drooping\",\n    \"slurred speech\",\n    \"cannot speak\",\n    \"arm weakness\"\n  ],\n\n  \"Bleeding Emergency\": [\n    \"heavy bleeding\",\n    \"blood loss\",\n    \"bleeding badly\"\n  ],\n\n  \"Neurological Emergency\": [\n    \"seizure\",\n    \"unconscious\",\n    \"fainted\",\n    \"bleeding in brain\",\n    \"confusion\"\n  ],\n\n  \"Trauma Emergency\": [\n    \"accident\",\n    \"head injury\",\n    \"fracture\",\n    \"broken bone\"\n  ],\n\n  \"Allergic Emergency\": [\n    \"allergic reaction\",\n    \"swollen tongue\",\n    \"swollen face\",\n    \"anaphylaxis\"\n  ],\n\n  \"Poisoning Emergency\": [\n    \"poison\",\n    \"overdose\",\n    \"drug overdose\"\n  ],\n\n  \"Mental Health Crisis\": [\n    \"suicide\",\n    \"self harm\",\n    \"kill myself\"\n  ]\n};\n\n// Default values\nlet isEmergency = false;\nlet category = \"General\";\nlet severity = \"Low\";\n\n// Detection\nfor (const [cat, keywords] of Object.entries(emergencyCategories)) {\n  if (keywords.some(keyword => input.includes(keyword))) {\n    isEmergency = true;\n    category = cat;\n\n    // Severity logic\n    if (\n      cat === \"Cardiac Emergency\" ||\n      cat === \"Stroke Emergency\" ||\n      cat === \"Respiratory Emergency\"\n    ) {\n      severity = \"Critical\";\n    } else {\n      severity = \"High\";\n    }\n\n    break;\n  }\n}\n\n// Return\nreturn {\n  json: {\n    originalInput: rawInput,\n    normalizedInput: input,\n    isEmergency,\n    category,\n    severity,\n    Timestamp: new Date().toISOString(),\n    PatientMessage: rawInput,\n    EmergencyType: category,\n    Severity: severity,\n    Status: \"Pending\"\n  }\n};"
      },
